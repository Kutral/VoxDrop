{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxDrop",
  "version": "0.0.9",
  "identifier": "com.voxdrop.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voxdrop",
        "label": "main",
        "width": 720,
        "height": 780,
        "minWidth": 520,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true,
        "hiddenTitle": true
      },
      {
        "title": "Voxdrop Pill",
        "label": "pill",
        "width": 320,
        "height": 48,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": true,
        "x": -9999,
        "y": -9999
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
